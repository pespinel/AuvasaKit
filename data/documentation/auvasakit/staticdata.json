g","code":["public struct Route {","    let id: String","    let shortName: String  \/\/ \"1\", \"L2\"","    let longName: String   \/\/ \"Universidad - Circular\"","    let type: RouteType    \/\/ .bus, .tram, etc.","    let color: String?     \/\/ Hex color","    \/\/ ... more properties","}"],"syntax":"swift"},{"type":"heading","anchor":"StopTime","text":"StopTime","level":3},{"type":"codeListing","code":["public struct StopTime {","    let tripId: String","    let stopId: String","    let arrivalTime: String      \/\/ \"14:30:00\"","    let departureTime: String    \/\/ \"14:30:00\"","    let stopSequence: Int        \/\/ Order in trip","    \/\/ ... more properties","}"],"syntax":"swift"},{"type":"heading","anchor":"Trip","text":"Trip","level":3},{"type":"codeListing","code":["public struct Trip {","    let id: String","    let routeId: String","    let serviceId: String","    let headsign: String?         \/\/ Destination","    let directionId: Int?         \/\/ 0 or 1","    let wheelchairAccessible: WheelchairAccessibility","    \/\/ ... more properties","}"],"syntax":"swift"},{"type":"heading","anchor":"Performance-Tips","text":"Performance Tips","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Use Nearby Search","type":"text"}]},{"type":"text","text":": When searching geographically, use "},{"type":"codeVoice","code":"findNearbyStops()"},{"type":"text","text":" instead of fetching all stops and filtering manually"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Limit Results"}]},{"text":": Use the ","type":"text"},{"type":"codeVoice","code":"limit"},{"text":" parameter to reduce data transfer:","type":"text"}],"type":"paragraph"},{"code":["let stops = try await client.fetchUpcomingDepartures(stopId: \"123\", limit: 5)"],"type":"codeListing","syntax":"swift"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text"