ocation: \\(stop.coordinate)\")","    print(\"  Wheelchair: \\(stop.wheelchairBoarding)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Search-Stops-by-Name","text":"Search Stops by Name","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find stops matching a query:"}]},{"type":"codeListing","code":["let stops = try await client.searchStops(query: \"plaza\")","","for stop in stops {","    print(\"\\(stop.name) (\\(stop.code ?? \"?\"))\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Find-Nearby-Stops","text":"Find Nearby Stops","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Search for stops within a radius:"}]},{"type":"codeListing","code":["let userLocation = Coordinate(latitude: 41.6523, longitude: -4.7245)","let nearbyStops = try await client.findNearbyStops(","    coordinate: userLocation,","    radiusMeters: 500",")","","for stop in nearbyStops {","    let distance = userLocation.distance(to: stop.coordinate)","    print(\"\\(stop.name): \\(Int(distance))m away\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Get-All-Stops","text":"Get All Stops","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch the complete stop database:"}]},{"type":"codeListing","code":["let allStops = try await client.fetchAllStops()","print(\"Total stops: \\(allStops.count)\")"],"syntax":"swift"},{"type":"heading","anchor":"Filter-Wheelchair-Accessible-Stops","text":"Filter Wheelchair Accessible Stops","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find stops with wheelchair boarding:"}]},{"type":"codeListing","code":["let accessibleStops = try await client.fetchWheelchairAccessibleStops()","","for stop in accessibleStops {","    print(\"♿️ \\(stop.name)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Working-with-Routes","text":"Working with Routes","level":2},{"type":"heading","anchor":"Get-All-Routes","text":"Get All Routes","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch all bus lines:"}]},{"type":"codeListing","code":["let routes = try await client.fetchRoutes()","","for route in routes {","    print(\"\\(route.shortName): \\(route.longName)\")","    if let color = route.color {","        print(\"  Color: #\\(color)\")","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Get-a-Specific-Route","text":"Get a Specific Route","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch a route by ID:"}]},{"type":"codeListing","code":["if let route = try await client.getRoute(id: \"L1\") {","    print(\"Route: \\(route.longName)\")","    print(\"  Type: \\(route.type)\")  \/\/ .bus, .tram, etc.","}"],"syntax":"swift"},{"type":"heading","anchor":"Search-Routes","text":"Search Routes","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find routes by name:"}]},{"type":"codeListing","code":["let routes = try await client.searchRoutes(query: \"circular\")","","for route in routes {","    print(\"\\(route.shortName): \\(route.longName)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Filter-by-Route-Type","text":"Filter by Route Type","level":3},{"type":"paragraph","inlineContent":[{"text":"Get routes of a specific type:","type":"text"}]},{"type":"codeListing","code":["let buses = try await client.fetchRoutes(type: .bus)","print(\"Bus routes: \\(buses.count)\")"],"syntax":"swift"},{"type":"heading","anchor":"Working-with-Schedules","text":"Working with Schedules","level":2},{"type":"heading","anchor":"Get-Schedule-for-a-Stop","text":"Get Schedule for a Stop","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch all scheduled departures from a stop:"}]},{"type":"codeListing","code":["let schedule = try await client.getSchedule(stopId: \"123\")","","for stopTime in schedule {","    print(\"Trip \\(stopTime.tripId)\")","    print(\"  Departure: \\(stopTime.departureTime)\")  \/\/ \"14:30:00\"","    print(\"  Sequence: \\(stopTime.stopSequence)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Get-Schedule-for-a-Specific-Date","text":"Get Schedule for a Specific Date","level":3},{"type":"paragraph","inlineContent":[{"text":"Fetch schedule for a particular day:","type":"text"}]},{"type":"codeListing","code":["let tomorrow = Date().addingTimeInterval(86400)","let schedule = try await client.getSchedule(stopId: \"123\", date: tomorrow)"],"syntax":"swift"},{"type":"heading","anchor":"Get-Upcoming-Departures","text":"Get Upcoming Departures","level":3},{"type":"paragraph","inlineContent":[{"text":"Fetch next departures after a specific time:","type":"text"}]},{"type":"codeListing","code":["\/\/ Current time in HH:MM:SS format","let now = \"14:30:00\"","","let upcoming = try await client.fetchUpcomingDepartures(","    stopId: \"123\",","    afterTime: now,","    limit: 10",")","","for stopTime in upcoming {","    print(\"Departure: \\(stopTime.departureTime)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Working-with-Trips","text":"Working with Trips","level":2},{"type":"heading","anchor":"Get-Trip-Information","text":"Get Trip Information","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch details about a specific trip:"}]},{"type":"codeListing","code":["if let trip = try await client.getTrip(id: \"TRIP_123\") {","    print(\"Trip: \\(trip.headsign ?? \"?\")\")","    print(\"  Route: \\(trip.routeId)\")","    print(\"  Direction: \\(trip.directionId ?? 0)\")","    print(\"  Wheelchair: \\(trip.wheelchairAccessible)\")","}"],"syntax":"swift"},{"type":"heading","anchor":"Get-Trips-for-a-Route","text":"Get Trips for a Route","level":3},{"type":"paragraph","inlineContent":[{"text":"Find all trips on a route:","type":"text"}]},{"type":"codeListing","code":["let trips = try await client.fetchTrips(routeId: \"L1\")","","for trip in trips {","    print(\"\\(trip.headsign ?? \"?\")\")","    print(\"  Direction: \\(trip.directionId ?? 0)\")","}"],"syntax":"swift"},{"type":"headi