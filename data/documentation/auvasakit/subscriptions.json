{"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Instead of manually polling for updates, AuvasaKit provides subscription APIs that deliver continuous data streams. Subscriptions use Swift’s "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":" and automatically handle:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Periodic polling (configurable interval, default 30s)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Error recovery with automatic retries"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Proper cleanup when cancelled"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Thread-safe operation with actors"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Vehicle Position Subscriptions","anchor":"Vehicle-Position-Subscriptions"},{"type":"heading","level":3,"text":"Subscribe to All Vehicles","anchor":"Subscribe-to-All-Vehicles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Receive updates for all active buses:"}]},{"type":"codeListing","code":["for await positions in client.subscribeToVehiclePositions() {","    print(\"Received \\(positions.count) vehicle positions\")","","    \/\/ Update your map or UI","    for vehicle in positions {","        updateMapMarker(","            id: vehicle.id,","            coordinate: vehicle.position,","            bearing: vehicle.bearing","        )","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Subscribe to Specific Route","anchor":"Subscribe-to-Specific-Route"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Track only buses on a particular route:"}]},{"type":"codeListing","code":["for await positions in client.subscribeToVehiclePositions(routeId: \"L1\") {","    print(\"Line 1 has \\(positions.count) active buses\")","","    for vehicle in positions {","        print(\"  \\(vehicle.vehicle.label ?? \"?\"): \\(vehicle.position)\")","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Track Nearby Vehicles","anchor":"Track-Nearby-Vehicles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a Task to filter positions by distance:"}]},{"type":"codeListing","code":["let userLocation = Coordinate(latitude: 41.6523, longitude: -4.7245)","","for await positions in client.subscribeToVehiclePositions() {","    let nearbyBuses = positions.filter {","        userLocation.distance(to: $0.position) < 1000  \/\/ Within 1km","    }","","    if !nearbyBuses.isEmpty {","        print(\"\\(nearbyBuses.count) buses nearby\")","        \/\/ Trigger notification or update UI","    }","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Trip Update Subscriptions","anchor":"Trip-Update-Subscriptions"},{"type":"heading","level":3,"text":"Subscribe to Stop Arrivals","anchor":"Subscribe-to-Stop-Arrivals"},{"type":"paragraph","inlineContent":[{"text":"Get continuous arrival predictions for a stop:","type":"text"}]},{"type":"codeListing","code":["for await updates in client.subscribeToTripUpdates(stopId: \"123\") {","    print(\"Arrival updates for stop 123:\")","","    for update in updates {","        \/\/ Find arrival time for this specific stop","        for stopUpdate in update.stopTimeUpdates where stopUpdate.stopId == \"123\" {","            if let arrival = stopUpdate.arrival {","                let arrivalDate = Date(timeIntervalSince1970: TimeInterval(arrival.time))","                print(\"  Trip \\(update.trip.routeId): \\(arrivalDate)\")","","                if let delay = arrival.delay {","                    print(\"    Delay: \\(delay)s\")","                }","            }","        }","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Subscribe to All Trip Updates","anchor":"Subscribe-to-All-Trip-Updates"},{"type":"paragraph","inlineContent":[{"text":"Monitor all active trips:","type":"text"}]},{"type":"codeListing","code":["for await updates in client.subscribeToTripUpdates() {","    print(\"Received \\(updates.count) trip updates\")","","    \/\/ Find trips with significant delays","    let delayedTrips = updates.filter { ($0.delay ?? 0) > 300 }  \/\/ > 5 min","","    if !delayedTrips.isEmpty {","        print(\"⚠️ \\(delayedTrips.count) trips delayed > 5 minutes\")","    }","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Alert Subscriptions","anchor":"Alert-Subscriptions"},{"type":"heading","level":3,"text":"Subscribe to All Alerts","anchor":"Subscribe-to-All-Alerts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor service disruptions:"}]},{"type":"codeListing","code":["for await alerts in client.subscribeToAlerts() {","    if !alerts.isEmpty {","        print(\"⚠️ \\(alerts.count) active alerts:\")","","        for alert in alerts {","            print(\"  \\(alert.headerText)\")","            print(\"  Severity: \\(alert.severity)\")","        }","","        \/\/ Show notification to user","        showAlertNotification(alerts)","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Subscribe to Route Alerts","anchor":"Subscribe-to-Route-Alerts"},{"type":"paragraph","inlineContent":[{"text":"Track alerts for a specific route:","type":"text"}]},{"type":"codeListing","code":["for await alerts in client.subscribeToAlerts(routeId: \"L1\") {","    if !alerts.isEmpty {","        print(\"Line 1 alerts:\")","        for alert in alerts {","            print(\"  \\(alert.descriptionText)\")","        }","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Subscribe to Stop Alerts","anchor":"Subscribe-to-Stop-Alerts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor alerts affecting a particular stop:"}]},{"type":"codeListing","code":["for await alerts in client.subscribeToAlerts(stopId: \"123\") {","    for alert in alerts {","        \/\/ Check if alert affects our stop","        if alert.informedEntities.contains(where: { $0.stopId == \"123\" }) {","            print(\"Alert at stop: \\(alert.headerText)\")","        }","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Subscribe to Active Alerts Only","anchor":"Subscribe-to-Active-Alerts-Only"},{"type":"paragraph","inlineContent":[{"text":"Filter for currently active alerts:","type":"text"}]},{"type":"codeListing","code":["for await alerts in client.subscribeToActiveAlerts() {","    print(\"\\(alerts.count) alerts active right now\")","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Managing Subscriptions","anchor":"Managing-Subscriptions"},{"type":"heading","level":3,"text":"Cancellation","anchor":"Cancellation"},{"type":"paragraph","inlineContent":[{"text":"Subscriptions run until cancelled. Use Swift’s structured concurrency:","type":"text"}]},{"type":"codeListing","code":["let task = Task {","    for await positions in client.subscribeToVehiclePositions() {","        updateUI(with: positions)","    }","}","","\/\/ Later, cancel the subscription","task.cancel()"],"syntax":"swift"},{"type":"heading","level":3,"text":"Structured Concurrency","anchor":"Structured-Concurrency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use task groups for multiple subscriptions:"}]},{"type":"codeListing","code":["await withTaskGroup(of: Void.self) { group in","    \/\/ Subscribe to vehicles","    group.addTask {","        for await positions in client.subscribeToVehiclePositions() {","            updateVehicles(positions)","        }","    }","","    \/\/ Subscribe to alerts","    group.addTask {","        for await alerts in client.subscribeToAlerts() {","            updateAlerts(alerts)","        }","    }","","    \/\/ Subscriptions run until task group is cancelled","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"SwiftUI Integration","anchor":"SwiftUI-Integration"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Task","type":"codeVoice"},{"text":" in SwiftUI:","type":"text"}]},{"type":"codeListing","code":["struct BusMapView: View {","    @State private var vehicles: [VehiclePosition] = []","    @State private var subscriptionTask: Task<Void, Never>?","","    var body: some View {","        Map {","            ForEach(vehicles) { vehicle in","                Annotation(vehicle.vehicle.label ?? \"?\", coordinate: vehicle.position.clLocation) {","                    BusMarker(vehicle: vehicle)","                }","            }","        }","        .onAppear {","            subscriptionTask = Task {","                for await positions in client.subscribeToVehiclePositions() {","                    vehicles = positions","                }","            }","        }","        .onDisappear {","            subscriptionTask?.cancel()","        }","    }","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Configuration","anchor":"Configuration"},{"type":"heading","level":3,"text":"Polling Interval","anchor":"Polling-Interval"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure the polling interval when creating the client:"}]},{"type":"codeListing","code":["let config = AuvasaClient.Configuration(","    pollingInterval: 15  \/\/ Poll every 15 seconds",")","let client = AuvasaClient(configuration: config)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shorter intervals provide more up-to-date data but increase network usage. The default 30 seconds balances freshness with efficiency."}]},{"type":"heading","level":3,"text":"Error Handling","anchor":"Error-Handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Subscriptions automatically retry on transient errors:"}]},{"type":"codeListing","code":["for await positions in client.subscribeToVehiclePositions() {","    \/\/ Stream continues even if individual requests fail","    \/\/ Errors are logged but don't break the subscription","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For critical errors (e.g., authentication failure), the stream will terminate and you can catch the error:","type":"text"}]},{"type":"codeListing","code":["do {","    for await positions in client.subscribeToVehiclePositions() {","        updateUI(with: positions)","    }","} catch {","    print(\"Subscription failed: \\(error)\")","    \/\/ Handle fatal error","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Best Practices","anchor":"Best-Practices"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Cancel Properly"}],"type":"strong"},{"type":"text","text":": Always cancel subscriptions when no longer needed to free resources"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use Structured Concurrency","type":"text"}],"type":"strong"},{"text":": Leverage task groups and task hierarchies for automatic cleanup","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Filter Early"}],"type":"strong"},{"type":"text","text":": Apply filters to reduce data processing"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Batch Updates","type":"text"}],"type":"strong"},{"text":": Consider debouncing UI updates when processing high-frequency streams","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Monitor Memory"}],"type":"strong"},{"text":": Large subscription buffers can consume memory - cancel inactive subscriptions","type":"text"}]}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/Subscriptions"},"sections":[],"metadata":{"modules":[{"name":"AuvasaKit"}],"role":"article","roleHeading":"Article","title":"Subscriptions"},"abstract":[{"type":"text","text":"Subscribe to continuous real-time updates using AsyncStream."}],"seeAlsoSections":[{"identifiers":["doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/RealTimeData","doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/AuvasaClient"],"anchor":"Related-Documentation","title":"Related Documentation"},{"identifiers":["doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/RealTimeData"],"generated":true,"anchor":"Real-Time-Features","title":"Real-Time Features"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/auvasakit\/subscriptions"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit"]]},"references":{"doc://auvasakit.AuvasaKit/documentation/AuvasaKit":{"kind":"symbol","role":"collection","title":"AuvasaKit","identifier":"doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit","url":"\/documentation\/auvasakit","type":"topic","abstract":[{"type":"text","text":"Modern Swift SDK for accessing AUVASA (Autobuses Urbanos de Valladolid) transit data."}]},"doc://auvasakit.AuvasaKit/documentation/AuvasaKit/RealTimeData":{"url":"\/documentation\/auvasakit\/realtimedata","title":"Real-Time Data","type":"topic","identifier":"doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/RealTimeData","role":"article","abstract":[{"type":"text","text":"Access live transit information from AUVASA’s GTFS Real-Time feed."}],"kind":"article"},"doc://auvasakit.AuvasaKit/documentation/AuvasaKit/AuvasaClient":{"type":"topic","fragments":[{"kind":"keyword","text":"actor"},{"kind":"text","text":" "},{"kind":"identifier","text":"AuvasaClient"}],"navigatorTitle":[{"kind":"identifier","text":"AuvasaClient"}],"title":"AuvasaClient","role":"symbol","url":"\/documentation\/auvasakit\/auvasaclient","identifier":"doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/AuvasaClient","kind":"symbol","abstract":[{"text":"Main client for accessing AUVASA bus data","type":"text"}]}}}