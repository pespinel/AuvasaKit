criptions",")","let client = AuvasaClient(configuration: config)"],"syntax":"swift","type":"codeListing"},{"type":"heading","text":"2. Fetch Real-Time Vehicle Positions","level":3,"anchor":"2-Fetch-Real-Time-Vehicle-Positions"},{"type":"paragraph","inlineContent":[{"text":"Get current positions of all active buses:","type":"text"}]},{"code":["let vehicles = try await client.fetchVehiclePositions()","","for vehicle in vehicles {","    print(\"Bus \\(vehicle.vehicle.label ?? \"?\"): \\(vehicle.position)\")","    if let speed = vehicle.speed {","        print(\"  Speed: \\(speed) m\/s\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Filter by a specific route:","type":"text"}]},{"code":["let route1Vehicles = try await client.fetchVehiclePositions(routeId: \"L1\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"3. Get Next Arrivals at a Stop","level":3,"anchor":"3-Get-Next-Arrivals-at-a-Stop"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine static schedules with real-time predictions:"}]},{"code":["let arrivals = try await client.getNextArrivals(stopId: \"123\", limit: 5)","","for arrival in arrivals {","    print(\"\\(arrival.route.shortName) to \\(arrival.trip.headsign ?? \"?\")\")","    print(\"  Scheduled: \\(arrival.scheduledTime)\")","","    if let estimated = arrival.estimatedTime {","        print(\"  Estimated: \\(estimated)\")","        if let delay = arrival.delay {","            print(\"  Delay: \\(delay) seconds\")","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"4. Find Nearby Stops","level":3,"anchor":"4-Find-Nearby-Stops"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Search for stops within a radius:"}]},{"type":"codeListing","code":["let userLocation = Coordinate(latitude: 41.6523, longitude: -4.7245)","let nearbyStops = try await client.findNearbyStops(","    coordinate: userLocation,","    radiusMeters: 500",")","","for stop in nearbyStops {","    print(\"\\(stop.name) - \\(stop.coordinate)\")","}"],"syntax":"swift"},{"type":"heading","text":"5. Subscribe to Real-Time Updates","anchor":"5-Subscribe-to-Real-Time-Updates","level":3},{"type":"paragraph","inlineContent":[{"text":"Use AsyncStream for continuous updates:","type":"text"}]},{"type":"codeListing","code":["for await positions in client.subscribeToVehiclePositions(routeId: \"L1\") {","    print(\"Received \\(positions.count) vehicle positions\")","    \/\/ Update your UI with latest positions","}"],"syntax":"swift"},{"type":"heading","text":"Importing Static Data","anchor":"Importing-Static-Data","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"On first use, download the GTFS static data:"}]},{"type":"codeListing","code":["\/\/ Download and import GTFS data (one-time operation)","try await client.updateStaticData()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This downloads stops, routes, schedules, and other static information. The data is stored locally in CoreData and only needs to be updated occasionally.","type":"text"}]},{"type":"heading","text":"Error Handling","anchor":"Error-Handling","level":2},{"type":"paragraph","inlineContent":[{"text":"Handle errors using Swift’s standard error handling:","type":"text"}]},{"type":"codeListing","code":["do {","    let vehicles = try await client.fetchVehiclePositions()","    \/\/ Process vehicles","} catch {","    print(\"Error fetching vehicles: \\(error)\")","}"],"syntax":"swift"},{"type":"heading","text":"Next Steps","anchor":"Next-Steps","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Learn about ","type":"text"},{"identifier":"doc:\/\/auvasakit.AuvasaKit\/documentation\/AuvasaKit\/RealTimeData","isActive":true,"type":"reference"},{"text":" features","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Explore ","type":"text"},{"isActive":true,"identifier":"do